{
  "compilerOptions": {
    "jsx": "react-jsx",
    "checkJs": false,
    "lib": ["ES2022", "DOM"],
    "target": "ES6",
    "module": "ES6",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 2,
    "paths": {
      "#cli/*": ["./src/cli/*"],
      "#ns/*": ["./src/ns/*"],
      "#server/*": ["./src/server/*"],
      "#static/*": ["./src/static/*"],
      "*": ["./src/*"]
    }
  },
  "exclude": ["node_modules", "build", "docker", "db"]
}
