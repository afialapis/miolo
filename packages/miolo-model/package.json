{
  "name": "miolo-model",
  "version": "3.0.0-beta.156",
  "description": "Data models for miolo world",
  "author": "Donato Lorenzo <donato@afialapis.com>",
  "contributors": [
    "Donato Lorenzo <donato@afialapis.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/afialapis/miolo.git"
  },
  "bugs": {
    "url": "https://github.com/afialapis/miolo/issues"
  },
  "homepage": "https://www.afialapis.com/os/miolo",
  "license": "MIT",

  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.mjs",
      "import": "./dist/miolo-model.mjs",
      "default": "./dist/miolo-model.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "lint": "npx xeira lint ./src",
    "reset": "rm -fr package-lock.json npm-lock.yaml dist/* && npm i",
    "clean": "rm -fr ./dist/*",
    "bundle": "npx xeira bundle --target=browser --source_index=./src/index.mjs --bundle_folder=./dist --bundle_name=miolo-model --bundle_extension=umd,mjs",
    "dist": "npm run clean && npm run bundle",
    "test": "NODE_OPTIONS=\"--conditions=development\" npx xeira test --files=./test/index.mjs"
  },
  "dependencies": {
  },
  "devDependencies": {
    "xeira": "^2.0.0-beta.10"
  }
}

