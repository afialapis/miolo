#
# vite plugins
# DEBUG=true
# DEBUG=tailwindcss:content


#
# We can run the demo with different auth modes:
# 
#  - guest : uses miolo's guest auth mode
#  - basic : uses miolo's basic auth mode
#  - creds : uses miolo's local and google auth modes
#
MIOLO_DEMO_AUTH_MODE=creds


#
# Miolo general
#
MIOLO_NAME=miolo-demo
MIOLO_PORT=8001
MIOLO_DEV_PORT=7001
MIOLO_HOSTNAME=localhost

#
# Database
#
MIOLO_DB_DIALECT=postgres
MIOLO_DB_HOST=localhost
MIOLO_DB_PORT=5432
MIOLO_DB_DATABASE=miolo
MIOLO_DB_USER=postgres
MIOLO_DB_PASSWORD=postgres


#
# Logging
#
MIOLO_LOG_LEVEL=debug
MIOLO_LOG_MAIL_ENABLED=true
#
# Build
#
MIOLO_BUILD_HTML_FILE=./cli/index.html
MIOLO_BUILD_CLIENT_ENTRY=./cli/entry-cli.jsx
MIOLO_BUILD_CLIENT_DEST=./dist/cli
MIOLO_BUILD_SERVER_SSR_ENTRY=./server/ssr/entry-server.jsx
MIOLO_BUILD_SERVER_ENTRY=./server/server.mjs
MIOLO_BUILD_SERVER_DEST=./dist/server
MIOLO_DEV_CONFIG_ENTRY=./server/config.mjs
MIOLO_DEV_WATCH_DIRS=./server

#
# Http & session
#
MIOLO_SESSION_SECURE=false