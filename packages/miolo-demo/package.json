{
  "name": "miolo-demo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "lint": "biome check ./src --reporter=github",
    "lint:fix": "biome check --write ./src --reporter=github",
    "create-bin": "npx miolo create-bin",
    "reset": "rm -fr package-lock.json npm-lock.yaml build/* && npm i",
    "dev": "npx miolo dev",
    "deb": "npx miolo deb",
    "build": "npx miolo build && npm run create-bin",
    "x-start": "npx miolo start",
    "x-stop": "npx miolo stop",
    "x-restart": "npx miolo restart",
    "start": "node ./build/server/run.mjs start",
    "stop": "node ./build/server/run.mjs stop",
    "restart": "node ./build/server/run.mjs restart",
    "prod": "npm run build && npm run start"
  },
  "type": "module",
  "imports": {
    "#cli/*": "./cli/*",
    "#server/*": "./server/*"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "intre": "^3.0.0-beta.3",
    "lucide-react": "^0.563.0",
    "miolo-react": "file:../miolo-react",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "joi": "^18.0.2",
    "miolo": "../miolo",
    "xeira": "^2.0.0-beta.10"
  },
  "XX__overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}