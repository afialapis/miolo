{
  "name": "miolo",
  "version": "3.0.0-beta.174",
  "description": "all-in-one koa-based server",
  "author": "Donato Lorenzo <donato@afialapis.com>",
  "contributors": [
    "Donato Lorenzo <donato@afialapis.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/afialapis/miolo.git"
  },
  "bugs": {
    "url": "https://github.com/afialapis/miolo/issues"
  },
  "homepage": "https://www.afialapis.com/os/miolo",
  "license": "MIT",
  "type": "module",
  "bin": {
    "miolo": "./bin/index.mjs"
  },
  "main": "./src/index.mjs",
  "exports": {
    "node": "./src/index.mjs",
    "import": "./src/index.mjs",
    "default": "./src/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "template",
    "template/.env",
    "template/.env.production",
    "template/.editorconfig",
    "template/.agent",
    "package.json"
  ],
  "scripts": {
    "lint": "biome check ./src ./bin --reporter=github",
    "lint:fix": "biome check --write ./src ./bin --reporter=github",
    "reset": "rm -fr package-lock.json npm-lock.yaml && npm i",
    "prepare-template": "node bin/create/prepare-template.mjs",
    "dist": "npm run prepare-template",
    "prepublishOnly": "npm run lint && npm run dist"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@dotenvx/dotenvx": "^1.60.1",
    "@koa/bodyparser": "^6.1.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "@maxmind/geoip2-node": "^6.3.4",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "cacheiro": "^0.5.0-beta.11",
    "calustra": "^1.0.0-beta.14",
    "cron": "^4.4.0",
    "deepmerge": "^4.3.1",
    "diskspace": "^2.0.0",
    "http-terminator": "^3.2.0",
    "intre": "^3.0.0-beta.4",
    "is-plain-object": "^5.0.0",
    "joi": "^18.1.2",
    "jwt-simple": "^0.5.6",
    "koa": "^3.2.0",
    "koa-compress": "^5.2.1",
    "koa-connect": "^2.1.1",
    "koa-favicon": "^2.1.0",
    "koa-mount": "^4.2.0",
    "koa-passport": "^6.0.0",
    "koa-proxies": "^0.12.4",
    "koa-ratelimit": "^6.0.0",
    "koa-session": "^7.0.2",
    "koa-static": "^5.0.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.5",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "rollup": "^4.60.1",
    "rollup-plugin-node-externals": "^8.1.2",
    "rollup-plugin-postcss": "^4.0.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "statuses": "^2.0.2",
    "tailwindcss": "^4.2.2",
    "tinguir": "^0.0.7",
    "vite": "^8.0.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yargs-parser": "^22.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}