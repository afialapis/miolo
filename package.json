{
  "name": "miolo",
  "version": "3.0.0-beta.174",
  "description": "all-in-one koa-based server",
  "author": "Donato Lorenzo <donato@afialapis.com>",
  "contributors": [
    "Donato Lorenzo <donato@afialapis.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/afialapis/miolo.git"
  },
  "bugs": {
    "url": "https://github.com/afialapis/miolo/issues"
  },
  "homepage": "https://www.afialapis.com/os/miolo",
  "license": "MIT",
  "type": "module",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean-root": "rm -fr node_modules package-lock.json .turbo",
    "clean-pkgs": "rm -fr packages/**/node_modules packages/**/.turbo",
    "reset": "npm run clean-root && npm run clean-pkgs && npm i && turbo telemetry disable >> /dev/null",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "dist": "turbo run dist",
    "test": "turbo run test",
    "create-demo-clean": "rm -fr demo/* && turbo run dist",
    "create-demo-guest": "npm run create-demo-clean && cd demo && node ../packages/miolo/bin/index.mjs create miolo-demo --d=. --auth=guest && npm run dev",
    "create-demo-basic": "npm run create-demo-clean && cd demo && node ../packages/miolo/bin/index.mjs create miolo-demo --d=. --auth=basic && npm run dev",
    "create-demo-passport": "npm run create-demo-clean && cd demo && node ../packages/miolo/bin/index.mjs create miolo-demo --d=. --auth=passport && npm run dev",
    "sample": "turbo run dev --filter=miolo-sample",
    "sample-deb": "turbo run deb --filter=miolo-sample",
    "sample-prod": "turbo run prod --filter=miolo-sample",
    "site": "npx arredemo build",
    "publish-miolo": "cd ./packages/miolo && npm run dist && npm publish && cd ../..",
    "publish-miolo-cli": "cd ./packages/miolo-cli && npm publish && cd ../..",
    "publish-miolo-react": "cd ./packages/miolo-react && npm publish && cd ../..",
    "publish-miolo-model": "cd ./packages/miolo-model && npm publish && cd ../..",
    "publish-all": "npm run site && npm run publish-miolo && npm run publish-miolo-cli && npm run publish-miolo-react && npm run publish-miolo-model"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "turbo": "^2.9.5"
  },
  "overrides": {
    "@babel/runtime": "^7.28.6",
    "ajv": "6.14.0",
    "body-parser": "^2.2.2",
    "cookie": "^1.1.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "on-headers": "^1.1.0",
    "path-to-regexp": "^8.3.0",
    "qs": "^6.14.1",
    "send": "^1.2.1",
    "serve-static": "^2.2.1",
    "tar": "^7.5.7",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=24"
  }
}