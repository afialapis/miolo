{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env*"],
  "tasks": {
    "reset": {
      "cache": false,
      "dependsOn": [],
      "outputs": [".turbo/**"]
    },
    "lint": {
      "cache": true,
      "dependsOn": [],
      "outputs": []
    },
    "dist": {
      "inputs": ["$TURBO_DEFAULT$", "!packages/miolo-demo/**", "!packages/miolo-sample/**", "!packages/miolo-test/**"],
      "cache": true,
      "dependsOn": ["^dist"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "outputs": []
    },
    "deb": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "outputs": []
    },
    "prod": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dist"],
      "outputs": []
    },
    "publish": {
      "cache": false,
      "dependsOn": ["^dist"],
      "outputs": []
    }
  }
}
