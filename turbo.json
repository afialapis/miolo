{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env*"
  ],
  "tasks": {
    "reset": {
      "cache": false,
      "dependsOn": [],
      "outputs": [
        ".turbo/**"
      ]
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!packages/miolo-demo/**"
      ],
      "cache": true
    },
    "lint:fix": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!packages/miolo-demo/**"
      ],
      "cache": false
    },
    "dist": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!packages/miolo-**/**"
      ],
      "cache": true,
      "dependsOn": [
        "^dist"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "outputs": []
    },
    "deb": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "outputs": []
    },
    "test": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "outputs": []
    },
    "sample": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "^dist"
      ],
      "outputs": []
    },
    "publish": {
      "cache": false,
      "dependsOn": [
        "^dist"
      ],
      "outputs": []
    }
  }
}